# Generate secrets: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=change-me-generate-a-random-value
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_TIME_ZONE=Europe/Lisbon
DJANGO_LOG_LEVEL=INFO
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_CONN_MAX_AGE=60
GUNICORN_WORKERS=3
IMAGE_TAG=latest
# Backups run only when the profile is enabled: COMPOSE_PROFILES=backup
BACKUP_INTERVAL_SECONDS=86400
BACKUP_KEEP_DAYS=30
POSTGRES_DB=financial-audit
POSTGRES_USER=financial-audit
POSTGRES_PASSWORD=change-me-generate-a-random-value
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5432
